{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/changesets/changelog",
		{
			"repo": "spencerbeggs/vitest-agent",
			"versionFiles": [
				{
					"glob": "plugin/.claude-plugin/plugin.json",
					"paths": ["$.version"],
					"package": "vitest-agent-plugin"
				}
			]
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"fixed": [
		["vitest-agent-plugin", "vitest-agent-reporter", "vitest-agent-sdk", "vitest-agent-cli", "vitest-agent-mcp"]
	],
	"ignore": ["example-basic"],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
