{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/changesets/changelog",
		{
			"repo": "spencerbeggs/vitest-agent-reporter",
			"versionFiles": [
				{
					"glob": "plugin/.claude-plugin/plugin.json",
					"paths": ["$.version"],
					"package": "vitest-agent-reporter"
				}
			]
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"fixed": [["vitest-agent-reporter", "vitest-agent-sdk", "vitest-agent-cli", "vitest-agent-mcp"]],
	"ignore": ["example-basic"],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
