{
	"name": "vitest-agent-reporter",
	"version": "1.3.1",
	"private": true,
	"description": "A Vitest reporter and agent platform for LLM coding agents with SQLite persistence, MCP server, CLI, and Claude Code plugin.",
	"keywords": ["vitest", "reporter", "llm", "ai", "agent", "testing", "coverage", "markdown", "github-actions"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent-reporter#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent-reporter/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent-reporter.git",
		"directory": "packages/reporter"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"prepare": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"effect": "catalog:silk",
		"vitest-agent-reporter-shared": "workspace:*"
	},
	"devDependencies": {
		"@savvy-web/rslib-builder": "^0.20.3",
		"@types/node": "catalog:silk",
		"@vitest/coverage-istanbul": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"@vitest/coverage-istanbul": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"vitest": "^4.1.0",
		"vitest-agent-reporter-cli": "workspace:*",
		"vitest-agent-reporter-mcp": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@vitest/coverage-istanbul": {
			"optional": true
		},
		"@vitest/coverage-v8": {
			"optional": true
		},
		"vitest": {
			"optional": false
		},
		"vitest-agent-reporter-cli": {
			"optional": false
		},
		"vitest-agent-reporter-mcp": {
			"optional": false
		}
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
