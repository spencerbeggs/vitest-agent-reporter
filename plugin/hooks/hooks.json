{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
						"timeout": 30,
						"statusMessage": "Loading vitest-agent context..."
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit-record.sh\"",
						"timeout": 5
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "mcp__(plugin_vitest-agent_mcp|vitest-agent_mcp)__.*",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-mcp.sh\"",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "mcp__(plugin_vitest-agent_mcp|vitest-agent_mcp)__(tdd_goal_delete|tdd_behavior_delete|tdd_artifact_record)",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-tdd-restricted.sh\"",
						"timeout": 5
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-record.sh\"",
						"timeout": 5
					}
				]
			},
			{
				"matcher": "Bash|Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-bash-tdd.sh\"",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-test-run.sh\"",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-git-commit.sh\"",
						"timeout": 10
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-record.sh\"",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-tdd-artifact.sh\"",
						"timeout": 10
					},
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-test-quality.sh\"",
						"timeout": 10
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-record.sh\"",
						"timeout": 10
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-record.sh\"",
						"timeout": 10
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact-record.sh\"",
						"timeout": 5
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start-tdd.sh\"",
						"timeout": 10
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop-tdd.sh\"",
						"timeout": 10
					}
				]
			}
		],
		"Elicitation": [
			{
				"hooks": [
					{
						"matcher": "*",
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/elicitation-session-id.sh\"",
						"timeout": 5
					}
				]
			}
		],
		"ElicitationResult": [
			{
				"hooks": [
					{
						"matcher": "*",
						"type": "command",
						"command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/elicitation-result-record.sh\"",
						"timeout": 5
					}
				]
			}
		]
	}
}
